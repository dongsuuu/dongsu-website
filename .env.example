# External API Configuration
# Set to 'true' to fetch data from external Virtual/ACP APIs
# Set to 'false' to use fallback data (default for MVP)
USE_EXTERNAL_DATA=false

# External API URLs (only used if USE_EXTERNAL_DATA=true)
VIRTUAL_API_URL=https://api.virtuals.io
VIRTUAL_API_KEY=your_api_key_here

# Public API URL for client-side requests
NEXT_PUBLIC_API_URL=http://localhost:3000
